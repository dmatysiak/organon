-- Building on Basics with cross-file references.

open Basics

-- @Barbara = every S is P
-- Barbara: every S is P; every Q is S; ∴ every Q is P
proof FromBarbara
  @Barbara
  every Q is S
  ∴ every Q is P

-- @Cesare = no S is P
-- Cesare (EAE-2): no S is P; every Q is S; ∴ no Q is P
proof FromCesare
  @Cesare
  every Q is S
  ∴ no Q is P

-- @Basics.Darii = some S is P
-- Darii: every P is Q; some S is P; ∴ some S is Q
proof QualifiedRef
  every P is Q
  @Basics.Darii
  ∴ some S is Q

