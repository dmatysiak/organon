-- Cross-tradition references: using conclusions from Strict
-- under a Full tradition. The tradition governs validation,
-- not consumption.

tradition Full

open Strict

proof ExtendedBaroco
  @Baroco
  every P is M
  ∴ some P is not P

proof Darapti
  every M is P
  every M is S
  ∴ some S is P

proof MixedRefs
  @Strict.Barbara
  @Darapti
  ∴ some S is P
