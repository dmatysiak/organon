{
  "name": "organon-syl",
  "displayName": "Organon Syllogistic",
  "description": "Syntax highlighting and LSP support for .syl syllogistic proof files",
  "version": "0.1.0",
  "publisher": "organon",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "syl",
        "aliases": ["Syllogistic", "syl"],
        "extensions": [".syl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "syl",
        "scopeName": "source.syl",
        "path": "./syntaxes/syl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "syl",
        "path": "./snippets/syl.json"
      }
    ],
    "configuration": {
      "title": "Organon Syllogistic",
      "properties": {
        "organon-syl.serverPath": {
          "type": "string",
          "default": "organon-syl-lsp",
          "description": "Path to the organon-syl-lsp binary. If not absolute, looked up on PATH."
        }
      }
    },
    "configurationDefaults": {
      "[syl]": {
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
