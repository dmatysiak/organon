{
  "Proof block": {
    "prefix": "proof",
    "body": [
      "proof ${1:Name}",
      "  ${2:every M is P}",
      "  ${3:every S is M}",
      "  ∴ ${4:every S is P}",
      ""
    ],
    "description": "Insert a proof block with two premises and a conclusion"
  },
  "Therefore": {
    "prefix": "therefore",
    "body": "∴",
    "description": "Insert the ∴ (therefore) symbol"
  },
  "Open namespace": {
    "prefix": "open",
    "body": "open ${1:Namespace}",
    "description": "Import proofs from another .syl file"
  },
  "Universal affirmative (A)": {
    "prefix": "every",
    "body": "every ${1:S} is ${2:P}",
    "description": "every S is P"
  },
  "Universal negative (E)": {
    "prefix": "no",
    "body": "no ${1:S} is ${2:P}",
    "description": "no S is P"
  },
  "Particular affirmative (I)": {
    "prefix": "someis",
    "body": "some ${1:S} is ${2:P}",
    "description": "some S is P"
  },
  "Particular negative (O)": {
    "prefix": "someisnot",
    "body": "some ${1:S} is not ${2:P}",
    "description": "some S is not P"
  }
}
